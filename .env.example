# Application
APP_NAME=rss-aggregator
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=Asia/Taipei

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/rss.db

# API Key
REQUIRE_API_KEY=true
DEFAULT_API_KEY=your-default-api-key-here

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# RSS Fetching
DEFAULT_FETCH_INTERVAL=0
FETCH_TIMEOUT=30
FETCH_RETRY_COUNT=3
FETCH_RETRY_DELAY=5
MAX_FEED_ITEMS=1000

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL=60

# Default Sources (comma-separated RSS feed URLs)
DEFAULT_SOURCES=

# CORS (comma-separated allowed origins, leave empty for all)
ALLOWED_ORIGINS=

# Docker Settings
DOCKER_CONTAINER_NAME=rss-aggregator
DOCKER_API_PORT=8000
DOCKER_WEB_PORT=8080
DOCKER_IMAGE_TAG=latest

# Frontend Settings (for Docker build)
VITE_API_BASE_URL=/api