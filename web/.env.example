# API Configuration
# Base URL for API requests (used by frontend)
VITE_API_BASE_URL=http://127.0.0.1:51085/api/v1

# Development Server Configuration
# Port for the Vite dev server
VITE_DEV_SERVER_PORT=3001

# Proxy target for API requests during development
# This should point to your backend server
VITE_API_PROXY_TARGET=http://127.0.0.1:51085