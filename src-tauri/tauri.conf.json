{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RSS Aggregator",
  "version": "0.11.1",
  "identifier": "com.rssaggregator.app",
  "build": {
    "beforeDevCommand": "uv run uvicorn src.main:app --reload",
    "beforeBuildCommand": "cd web && pnpm build",
    "devUrl": "http://localhost:8000",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RSS Aggregator",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self' app: ipc:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' app: ipc: http://localhost:8000 ws://localhost:8000; img-src 'self' data: https:; font-src 'self' data:; object-src 'none'; frame-ancestors 'none'"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "deb", "appimage"],
    "externalBin": [
      "binaries/rss-sidecar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.svg",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
